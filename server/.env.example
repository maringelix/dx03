NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dx03
DB_USER=admin
# Required at runtime. Generate locally with: openssl rand -base64 32
DB_PASSWORD=<change_me>

# CORS (comma-separated allow-list)
CORS_ORIGIN=http://localhost:5173

# Required in production for /metrics, /api/metrics, /api/health-history,
# /health/ready. Min 32 chars. Generate with: openssl rand -base64 48
METRICS_TOKEN=<change_me_min_32_chars>

# Logging
LOG_LEVEL=info
